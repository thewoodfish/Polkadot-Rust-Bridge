{"source":{"hash":"0xbf139623b0d8a902772624a1c3721e50cec67c5925dd3ad30f69b9308252b8d0","language":"ink! 5.1.1","compiler":"rustc 1.89.0-nightly","wasm":"","build_info":{"build_mode":"Release","cargo_contract_version":"4.1.3","rust_toolchain":"nightly-aarch64-apple-darwin","wasm_opt_settings":{"keep_debug_symbols":false,"optimization_passes":"Z"}}},"contract":{"name":"rust_bridge_ink","version":"0.1.0","authors":["Polkadot Rust Bridge"]},"image":null,"spec":{"constructors":[{"args":[],"default":false,"docs":["Constructor — contract has no state."],"label":"new","payable":false,"returnType":{"displayName":["ink_primitives","ConstructorResult"],"type":1},"selector":"0x9bae9d5e"}],"docs":[],"environment":{"accountId":{"displayName":["AccountId"],"type":16},"balance":{"displayName":["Balance"],"type":5},"blockNumber":{"displayName":["BlockNumber"],"type":20},"chainExtension":{"displayName":["ChainExtension"],"type":21},"hash":{"displayName":["Hash"],"type":18},"maxEventTopics":4,"staticBufferSize":16384,"timestamp":{"displayName":["Timestamp"],"type":19}},"events":[],"lang_error":{"displayName":["ink","LangError"],"type":3},"messages":[{"args":[{"label":"inputs","type":{"displayName":["Vec"],"type":4}}],"default":false,"docs":[" Compute a Poseidon-like hash over a sequence of `u128` field elements.",""," Uses a sponge construction with width-2 state and capacity 1:"," - `state[0]` is the rate lane (absorbs input),"," - `state[1]` is the capacity lane (starts at `inputs.len() as u128`","   for domain separation).",""," Returns the first (rate) state word after the final permutation."],"label":"poseidon_hash","mutates":false,"payable":false,"returnType":{"displayName":["ink","MessageResult"],"type":6},"selector":"0x42762451"},{"args":[{"label":"a","type":{"displayName":["Vec"],"type":7}},{"label":"b","type":{"displayName":["Vec"],"type":7}}],"default":false,"docs":[" Signed dot product of two equal-length vectors.",""," Panics (reverts the transaction) on overflow — consis