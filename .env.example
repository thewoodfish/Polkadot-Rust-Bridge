# =============================================================================
# .env.example — copy to .env and fill in all values before deploying.
# The .env file is in .gitignore and will never be committed.
# =============================================================================

# WebSocket or HTTPS RPC endpoint for the target chain.
# Westend Asset Hub testnet:   wss://westend-asset-hub-rpc.polkadot.io
# Paseo testnet:               wss://paseo-asset-hub-rpc.polkadot.io
# Local Substrate dev node:    ws://127.0.0.1:9944
POLKADOT_HUB_RPC_URL=

# EVM private key (0x-prefixed) for the Solidity deployer account.
# This account must hold enough DOT to cover gas on the target chain.
# Never commit a real key — use a testnet-only throwaway key here.
DEPLOYER_PRIVATE_KEY=

# 12 or 24-word BIP-39 seed phrase for the Substrate (ink!) deployer.
# Used only by scripts/deploy-ink.sh for cargo contract instantiate.
# Never commit a real seed — use a testnet-only throwaway seed here.
SUBSTRATE_SEED=

# AccountId32 of the deployed rust_bridge_ink! contract, as a 0x-prefixed
# 64-character hex string (NOT the SS58 address).
#
# How to get this value after running scripts/deploy-ink.sh:
#   subkey inspect <SS58_ADDRESS> --output-type json | jq -r '.publicKey'
# Then prepend 0x:
#   INK_CONTRACT_ADDRESS=0x<64 hex chars>
INK_CONTRACT_ADDRESS=
