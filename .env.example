# =============================================================================
# .env.example — copy to .env and fill in all values before deploying.
# The .env file is in .gitignore and will never be committed.
#
# For local benchmarking (npm test / npm run benchmark), no .env is needed.
# =============================================================================

# WebSocket or HTTPS RPC endpoint for the target chain.
# Polkadot Hub Testnet (Paseo, EVM-compatible, chain ID 420420417):
#   https://eth-rpc-testnet.polkadot.io/
#   https://services.polkadothub-rpc.com/testnet
POLKADOT_HUB_RPC_URL=https://eth-rpc-testnet.polkadot.io/

# EVM private key (0x-prefixed, 66 chars) for the Solidity deployer account.
# Generate: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"
# Fund the derived address at: https://faucet.polkadot.io
#   → Polkadot testnet (Paseo) → Hub (smart contracts)
DEPLOYER_PRIVATE_KEY=

# 12 or 24-word BIP-39 seed phrase for the Substrate (ink!) deployer.
# Used only by scripts/deploy-ink.sh for cargo contract instantiate.
# Fund the SS58 address at the same faucet above.
SUBSTRATE_SEED=

# AccountId32 of the deployed rust_bridge_ink! contract, as a 0x-prefixed
# 64-character hex string (NOT the SS58 address).
#
# After running scripts/deploy-ink.sh, convert the printed SS58 address:
#   subkey inspect <SS58_ADDRESS> --output-type json | jq -r '.publicKey'
# Then prepend 0x:
#   INK_CONTRACT_ADDRESS=0x<64 hex chars>
INK_CONTRACT_ADDRESS=
